<div class="sticky-wrapper">
    <header class="site-header">
        
        <a href="/" class="logo">StoryLoom</a>
        
        <div class="search-container">
            <form action="/search" method="GET" style="display:flex; width:100%;">
                <input type="text" name="q" placeholder="Search and discover...">
                <button type="submit" class="search-btn">Go!</button>
            </form>
        </div>
        
        <div class="header-auth">
            {{#currentUser}}
                <div class="dropdown" style="display: inline-block;">
                    <span class="dropbtn" style="font-weight: bold; color: #333; cursor: pointer; padding: 10px;">
                        Welcome, {{currentUser}} ▼
                    </span>
                    
                    <div class="dropdown-content" style="right: 0; min-width: 160px; text-align: left; box-shadow: 0px 8px 16px 0px rgba(0,0,0,0.2);">
                        
                        <a href="/bookmarks" style="display: block; padding: 12px 16px; text-decoration: none; color: black;">★ My Bookmarks</a>
                        
                        <a href="/shelves" style="display: block; padding: 12px 16px; text-decoration: none; color: black;">📚 My Shelves</a>

                        <form action="/logout" method="POST" style="margin: 0; padding: 0;">
                            <input type="hidden" name="_csrf" value="{{_csrfToken}}">
                            <button type="submit" style="width: 100%; text-align: left; background: none; border: none; padding: 12px 16px; color: #990000; font-size: 1em; cursor: pointer; display: block; font-family: inherit;">
                                🚪 Log Out
                            </button>
                        </form>

                    </div>
                </div>
            {{/currentUser}}
            
            {{^currentUser}}
                <a href="/login" class="auth-login">Log In</a>
                <a href="/register" class="auth-signup">Sign Up</a>
            {{/currentUser}}
        </div>

    </header>
    
    <nav class="sub-nav">
        <div class="dropdown">
            <a href="/about" class="dropbtn">About ▼</a>
            <div class="dropdown-content">
                <a href="/about">About the website</a>
                <a href="/contact">Contact us</a>
                <a href="/faq">FAQ</a>
            </div>
        </div>
        <a href="/frequently-downloaded">Frequently Downloaded</a>
        <a href="/categories">Categories</a>
        <a href="/search">Search Options</a>
    </nav>
</div>

<style>
    .header-auth .dropdown-content a:hover, 
    .header-auth .dropdown-content button:hover {
        background-color: #f1f1f1 !important;
    }
</style>