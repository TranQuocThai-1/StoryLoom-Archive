<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Reading: {{book.title}}</title>
    
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jszip/3.1.5/jszip.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/epubjs/dist/epub.min.js"></script>
    
    <style>
        body { 
            margin: 0; 
            padding: 0;
            background-color: #ffffff; 
            font-family: sans-serif;
            display: flex;
            flex-direction: column;
            height: 100vh;
            overflow: hidden; 
        }

        #top-bar {
            height: 50px;
            flex-shrink: 0; 
            background: #fcfcfc;
            border-bottom: 1px solid #eaeaea;
            display: flex;
            align-items: center;
            padding: 0 25px;
            z-index: 100;
        }

        #top-bar a { color: #555; text-decoration: none; font-weight: bold; font-size: 14px; transition: color 0.2s; }
        #top-bar a:hover { color: #000; }

        #viewer-container { 
            flex: 1; 
            width: 100%; 
            display: flex; 
            justify-content: center; 
            overflow: hidden; 
            background-color: #ffffff;
            font-family: Georgia, serif !important;
            color: #222 !important;
            font-size: 18px !important;
            line-height: 1.8 !important;
            text-align: left; 
        }

        /* THE FIX: Increased max-width from 900px to 1300px for a much wider reading area */
        #viewer { 
            width: 100%; 
            max-width: 1300px; 
            height: 100%; 
            padding: 20px 40px; 
            box-sizing: border-box;
            overflow-x: hidden; 
        }

        #notes-sidebar {
            position: fixed;
            top: 50px; 
            right: -350px; 
            width: 350px;
            height: calc(100vh - 50px);
            background: #fcfbf8;
            border-left: 1px solid #e1dbce;
            box-shadow: -4px 0 15px rgba(0,0,0,0.05);
            transition: right 0.3s ease-in-out;
            z-index: 200;
            display: flex;
            flex-direction: column;
        }

        #notes-sidebar.open {
            right: 0; 
        }

        #notes-toggle {
            position: absolute;
            top: 40%;
            left: -40px;
            width: 40px;
            height: 60px;
            background-color: #990000;
            color: white;
            border: none;
            border-radius: 5px 0 0 5px;
            cursor: pointer;
            font-size: 18px;
            display: flex;
            align-items: center;
            justify-content: center;
            box-shadow: -2px 0 5px rgba(0,0,0,0.1);
        }
        #notes-toggle:hover { background-color: #7a0000; }

        .sidebar-content {
            padding: 20px;
            display: flex;
            flex-direction: column;
            flex: 1;
        }

        .sidebar-content textarea {
            flex: 1;
            width: 100%;
            padding: 15px;
            font-family: 'Courier New', Courier, monospace;
            font-size: 0.95em;
            border: 1px solid #ccc;
            border-radius: 4px;
            resize: none; 
            box-sizing: border-box;
            line-height: 1.5;
            margin-top: 10px;
            margin-bottom: 15px;
        }
    </style>
</head>
<body>

    <div id="top-bar">
        <a href="/book/{{book.id}}">← Back to Details</a>
    </div>

    <div id="viewer-container">
        <div id="viewer"></div>
    </div>

    {{#currentUser}}
    <div id="notes-sidebar">
        <button id="notes-toggle" title="Toggle Notes">◀</button>
        
        <div class="sidebar-content">
            <h3 style="margin: 0; color: #333;">📝 My Notes</h3>
            <p style="font-size: 0.85em; color: #666; margin-bottom: 5px;">Your private annotations for this book.</p>
            
            <form action="/annotations/save" method="POST" style="flex: 1; display: flex; flex-direction: column;">
                <input type="hidden" name="{{_csrf.parameterName}}" value="{{_csrf.token}}"/>
                <input type="hidden" name="bookId" value="{{book.id}}"/>
                
                <textarea name="content" placeholder="Jot down thoughts while you read...">{{#annotation}}{{content}}{{/annotation}}</textarea>
                
                <div style="display: flex; justify-content: space-between; align-items: center;">
                    <span style="font-size: 0.75em; color: #888; font-style: italic;">
                        {{#annotation}}Saved: {{lastUpdated}}{{/annotation}}
                    </span>
                    <button type="submit" style="background-color: #00635d; color: white; border: none; padding: 8px 15px; cursor: pointer; font-weight: bold; border-radius: 4px;">Save</button>
                </div>
            </form>
        </div>
    </div>
    {{/currentUser}}

    <script>
        var bookUrl = "http://127.0.0.1:9000/storyloom-archive/{{book.epubFilePath}}";
        var book = ePub(bookUrl);
        
        var rendition = book.renderTo("viewer", {
            manager: "continuous",
            flow: "scrolled",
            width: "100%",
            height: "100%"
        });

        rendition.themes.default({
            "html, body": {
                "margin": "0 !important",
                "padding": "0 !important",
                "max-width": "100% !important",
                "overflow-x": "hidden !important"
            },
            "*": {
                "max-width": "100% !important",
                "box-sizing": "border-box !important",
                "word-wrap": "break-word !important",
                "overflow-wrap": "break-word !important"
            },
            "pre, code, .pgmonospaced": {
                "white-space": "pre-wrap !important",
                "word-break": "break-word !important",
                "font-family": "inherit !important"
            },
            "img": {
                "max-width": "100% !important",
                "height": "auto !important",
                "display": "block !important",
                "margin": "0 auto !important"
            }
        });
        
        book.ready.then(() => {
            return rendition.display();
        }).then(() => {
            if (book.spine && book.spine.length > 1) {
                return rendition.display(book.spine.get(1).href);
            }
        }).catch(function(err) {
            console.error("ePub Engine Error:", err);
            document.getElementById("viewer").innerHTML = "<div style='padding: 50px; text-align: center; color: #990000; font-family: sans-serif;'><h3>Failed to load this eBook.</h3><p>The file formatting may be corrupted or unsupported.</p></div>";
        });

        {{#currentUser}}
        document.addEventListener("DOMContentLoaded", function() {
            const toggleBtn = document.getElementById("notes-toggle");
            const sidebar = document.getElementById("notes-sidebar");

            toggleBtn.addEventListener("click", function() {
                sidebar.classList.toggle("open");
                if (sidebar.classList.contains("open")) {
                    toggleBtn.textContent = "▶"; 
                } else {
                    toggleBtn.textContent = "◀"; 
                }
            });
        });
        {{/currentUser}}
    </script>

</body>
</html>