            <div class="stats-quick-links">
                <p><strong>Top Books:</strong> <a href="#ebooks-yesterday">Yesterday</a> - <a href="#ebooks-7days">7 days</a> - <a href="#ebooks-30days">30 days</a></p>
                <p><strong>Top Authors:</strong> <a href="#authors-yesterday">Yesterday</a> - <a href="#authors-7days">7 days</a> - <a href="#authors-30days">30 days</a></p>
