                    <h2>Literature & Fiction</h2>
                    <ul class="dashed-list">
                        <li><a href="/category?name=Adventure">Adventure</a></li>
                        <li><a href="/category?name=American%20Literature">American Literature</a></li>
                        <li><a href="/category?name=Arthurian%20Legends">Arthurian Legends</a></li>
                        <li><a href="/category?name=Classics%20of%20Literature">Classics of Literature</a></li>
                        <li><a href="/category?name=Crime%20Fiction">Crime Fiction</a></li>
                        <li><a href="/category?name=Detective%20Fiction">Detective Fiction</a></li>
                        <li><a href="/category?name=Folklore">Folklore</a></li>
                        <li><a href="/category?name=Gothic%20Fiction">Gothic Fiction</a></li>
                        <li><a href="/category?name=Historical%20Fiction">Historical Fiction</a></li>
                        <li><a href="/category?name=Humour">Humour</a></li>
                        <li><a href="/category?name=Literature%20-%20Other">Literature - Other</a></li>
