<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Reading: {{book.title}}</title>
    
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jszip/3.1.5/jszip.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/epubjs/dist/epub.min.js"></script>
    
    <style>
        /* Modern, robust Flexbox layout for distraction-free reading */
        body { 
            margin: 0; 
            padding: 0;
            background-color: #ffffff; 
            font-family: sans-serif;
            display: flex;
            flex-direction: column;
            height: 100vh;
            overflow: hidden; /* Only the book scrolls */
        }

        /* Fixed Top Bar (Standard text look from index page) */
        #top-bar {
            height: 50px;
            flex-shrink: 0; /* Prevents the bar from getting squished */
            background: #fcfcfc;
            border-bottom: 1px solid #eaeaea;
            display: flex;
            align-items: center;
            padding: 0 25px;
            z-index: 100;
        }

        #top-bar a {
            color: #555;
            text-decoration: none;
            font-weight: bold;
            font-size: 14px;
            transition: color 0.2s;
        }

        #top-bar a:hover { color: #000; }

        /* Container with wider width, no overlaps, and Georgia text styling */
        #viewer-container { 
            flex: 1; /* Takes up exactly the remaining height */
            width: 100%; 
            display: flex; 
            justify-content: center; 
            overflow: hidden; /* Important for the ePub engine math */
            background-color: #ffffff;
            /* Georgia text styling for classic book feel from original Frankenstein request */
            font-family: Georgia, serif !important;
            color: #222 !important;
            font-size: 18px !important;
            line-height: 1.8 !important;
            text-align: left; /* Left justification from index.mustache */
        }

        #viewer { 
            width: 100%; 
            max-width: 900px; /* Wider text area as requested */
            height: 100%; 
        }
    </style>
</head>
<body>

    <div id="top-bar">
        <a href="/book/{{book.id}}">← Back to Details</a>
    </div>

    <div id="viewer-container">
        <div id="viewer"></div>
    </div>

    <script>
        var bookUrl = "http://127.0.0.1:9000/storyloom-archive/{{book.epubFilePath}}";
        var book = ePub(bookUrl);
        
        var rendition = book.renderTo("viewer", {
            manager: "continuous",
            flow: "scrolled",
            width: "100%",
            height: "100%"
        });

        rendition.hooks.content.register(function(contents) {
            contents.addStylesheetRules([
                // Simple, clean typography. No complex absolute positioning.
                ["body", ["padding", "30px 40px !important"]],
                
                // Constraints images so they don't break the layout. They will be smaller, not a "lil bigger".
                ["img", ["max-width", "100% !important"], ["max-height", "75vh !important"], ["object-fit", "contain"], ["display", "block"], ["margin", "0 auto"]]
            ]);
        });
        
        rendition.display();

        // New, robust strategy: Programmatically skip the cover spine item.
        book.ready.then(() => {
            // After the book is ready and displayed, jump past the cover item in the spine.
            // This is safer than a time-based jump and guarantees we land on the text.
            return rendition.display();
        }).then(() => {
            // Jump to the second item in the spine (index 1), skipping the cover.
            return rendition.spine.get(1).display();
        });
    </script>

</body>
</html>